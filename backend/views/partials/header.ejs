<header>
  <a href="/" class="logo">Leo<span>&</span>Isa</a>
  <div class="header-right">
    <button class="btn-rules" id="btnRules">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="15" height="15"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Regras
    </button>
    <% if (user) { %>
      <% if (user.isAdmin) { %>
        <a href="/admin" class="btn-admin-toggle">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Admin
        </a>
      <% } %>
      <div class="user-pill">
        <% if (user.profileImage) { %>
          <img src="<%= user.profileImage %>" alt="<%= user.displayName %>" class="user-avatar-img">
        <% } else { %>
          <div class="user-avatar"><%= user.displayName.charAt(0).toUpperCase() %></div>
        <% } %>
        <span class="user-name"><%= user.displayName %></span>
        <form action="/auth/logout" method="POST" style="margin:0">
          <button type="submit" class="btn-logout">Sair</button>
        </form>
      </div>
    <% } else { %>
      <a href="/auth/twitch" class="btn-twitch">
        <svg viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
        Entrar com Twitch
      </a>
    <% } %>
  </div>
</header>