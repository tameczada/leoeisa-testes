<%- include('../partials/head') %>
<link rel="stylesheet" href="/css/admin.css">
<style>
  .logs-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .8rem; margin-bottom: 1.6rem; }
  .logs-filters { display: flex; gap: .45rem; flex-wrap: wrap; }
  .filter-chip {
    padding: .32rem .75rem; border-radius: 20px; font-size: .75rem; font-weight: 600;
    border: 1px solid var(--border); color: var(--muted); background: var(--surface2);
    cursor: pointer; transition: all .18s; text-decoration: none; white-space: nowrap;
  }
  .filter-chip:hover { border-color: var(--border2); color: var(--text); }
  .filter-chip.active { background: rgba(245,158,11,.15); border-color: rgba(245,158,11,.4); color: var(--admin); }

  .log-table { width: 100%; border-collapse: collapse; }
  .log-table th {
    text-align: left; font-size: .68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; color: var(--muted); padding: .5rem .8rem;
    border-bottom: 1px solid var(--border);
  }
  .log-table td { padding: .65rem .8rem; border-bottom: 1px solid var(--border); vertical-align: middle; font-size: .83rem; }
  .log-table tr:last-child td { border-bottom: none; }
  .log-table tr:hover td { background: var(--surface2); }

  .log-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .22rem .6rem; border-radius: 6px; font-size: .7rem; font-weight: 700;
    letter-spacing: .5px; white-space: nowrap;
  }
  .log-badge.VOTE         { background: rgba(139,92,246,.12); color: #a78bfa; border: 1px solid rgba(139,92,246,.25); }
  .log-badge.VOTE_RETURN  { background: rgba(59,130,246,.12); color: #60a5fa; border: 1px solid rgba(59,130,246,.25); }
  .log-badge.MOVIE_ADD    { background: rgba(34,197,94,.12);  color: #4ade80; border: 1px solid rgba(34,197,94,.25); }
  .log-badge.MOVIE_REMOVE { background: rgba(239,68,68,.12);  color: #f87171; border: 1px solid rgba(239,68,68,.25); }
  .log-badge.MOVIE_EDIT   { background: rgba(245,158,11,.12); color: var(--admin); border: 1px solid rgba(245,158,11,.25); }
  .log-badge.RESET_ALL    { background: rgba(239,68,68,.18);  color: #fca5a5; border: 1px solid rgba(239,68,68,.35); }
  .log-badge.RESET_MOVIE  { background: rgba(249,115,22,.12); color: #fb923c; border: 1px solid rgba(249,115,22,.25); }

  .log-user { display: flex; align-items: center; gap: .5rem; }
  .log-avatar { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .log-avatar-placeholder { width: 22px; height: 22px; border-radius: 50%; background: var(--surface3); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: .6rem; color: var(--muted); }
  .log-name { font-weight: 500; }
  .log-sub  { font-size: .72rem; color: var(--muted); }
  .log-time { font-size: .75rem; color: var(--muted); white-space: nowrap; }

  .pagination { display: flex; align-items: center; justify-content: center; gap: .4rem; margin-top: 1.8rem; }
  .page-btn {
    padding: .4rem .75rem; border-radius: 8px; border: 1px solid var(--border);
    background: var(--surface2); color: var(--text); font-size: .82rem; font-weight: 500;
    cursor: pointer; text-decoration: none; transition: all .15s;
  }
  .page-btn:hover { border-color: var(--border2); }
  .page-btn.active { background: rgba(245,158,11,.15); border-color: rgba(245,158,11,.4); color: var(--admin); }
  .page-btn.disabled { opacity: .35; pointer-events: none; }

  .empty-logs { text-align: center; padding: 3rem 1rem; color: var(--muted); font-size: .9rem; }
  .log-count { font-size: .78rem; color: var(--muted); }

  .btn-clear {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .38rem .85rem; border-radius: 8px; font-size: .78rem; font-weight: 600;
    border: 1px solid rgba(239,68,68,.35); background: rgba(239,68,68,.08); color: #f87171;
    cursor: pointer; transition: all .18s; font-family: inherit;
  }
  .btn-clear:hover { background: rgba(239,68,68,.18); border-color: rgba(239,68,68,.6); }

  /* Modal */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,.6); backdrop-filter: blur(4px);
    align-items: center; justify-content: center; padding: 1rem;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 1.8rem; max-width: 340px; width: 100%;
    box-shadow: 0 24px 60px rgba(0,0,0,.5);
  }
  .modal-icon { font-size: 2rem; margin-bottom: .5rem; }
  .modal-title { font-size: 1rem; font-weight: 700; margin-bottom: .4rem; }
  .modal-desc { font-size: .83rem; color: var(--muted); margin-bottom: 1.4rem; line-height: 1.5; }
  .modal-actions { display: flex; gap: .6rem; justify-content: flex-end; }
  .modal-cancel {
    padding: .48rem 1rem; border-radius: 8px; border: 1px solid var(--border);
    background: var(--surface2); color: var(--text); font-size: .82rem; font-weight: 600;
    cursor: pointer; font-family: inherit;
  }
  .modal-confirm {
    padding: .48rem 1rem; border-radius: 8px;
    border: 1px solid rgba(239,68,68,.5); background: rgba(239,68,68,.15);
    color: #f87171; font-size: .82rem; font-weight: 600;
    cursor: pointer; font-family: inherit;
  }
  .modal-confirm:hover { background: rgba(239,68,68,.28); }

  /* Toast */
  #toast {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 1100;
    padding: .6rem 1.1rem; border-radius: 10px; font-size: .82rem; font-weight: 600;
    background: var(--surface2); border: 1px solid var(--border); color: var(--text);
    opacity: 0; transform: translateY(8px); transition: all .25s; pointer-events: none;
  }
  #toast.show { opacity: 1; transform: translateY(0); }
  #toast.ok  { border-color: rgba(34,197,94,.4); color: #4ade80; background: rgba(34,197,94,.1); }
  #toast.err { border-color: rgba(239,68,68,.4); color: #f87171; background: rgba(239,68,68,.1); }

  .secret-badge {
    display: inline-flex; align-items: center; gap: .35rem;
    background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25);
    color: #f87171; border-radius: 6px; padding: .18rem .55rem;
    font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  }
</style>
<%- include('../partials/header') %>

<!-- Modal de confirmação -->
<div class="modal-overlay" id="clearModal">
  <div class="modal-box">
    <div class="modal-icon">🗑</div>
    <div class="modal-title" id="modalTitle">Limpar logs</div>
    <div class="modal-desc" id="modalDesc">Esta ação não pode ser desfeita.</div>
    <div class="modal-actions">
      <button class="modal-cancel" id="modalCancel">Cancelar</button>
      <button class="modal-confirm" id="modalConfirm">Sim, limpar</button>
    </div>
  </div>
</div>

<div id="toast"></div>

<div class="admin-wrapper">
  <div class="admin-sidebar">
    <nav class="admin-nav">
      <a href="/admin?tab=overview" class="admin-nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Visão Geral
      </a>
      <a href="/admin?tab=movies" class="admin-nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4"/></svg>
        Filmes
      </a>
      <a href="/admin/users" class="admin-nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        Usuários
      </a>
      <a href="/admin/logs" class="admin-nav-item active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Logs
      </a>
      <a href="/" class="admin-nav-item admin-nav-back">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Voltar ao Site
      </a>
    </nav>
  </div>

  <main class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar-left">
        <span class="admin-badge">Admin</span>
        <span class="secret-badge">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="10" height="10"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
          Oculto
        </span>
        <h1>Logs de Auditoria</h1>
      </div>
      <div style="display:flex;align-items:center;gap:.8rem;">
        <span class="log-count"><%= total.toLocaleString('pt-BR') %> registro<%= total !== 1 ? 's' : '' %></span>
        <% if (total > 0) { %>
        <button class="btn-clear" id="btnClear">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Limpar<%= activeAction ? ' filtro' : ' tudo' %>
        </button>
        <% } %>
      </div>
    </div>

    <!-- Filtros -->
    <div class="logs-header">
      <div class="logs-filters">
        <a href="/admin/logs" class="filter-chip <%= activeAction === '' ? 'active' : '' %>">Todos</a>
        <a href="/admin/logs?action=VOTE" class="filter-chip <%= activeAction === 'VOTE' ? 'active' : '' %>">🗳 Votos</a>
        <a href="/admin/logs?action=VOTE_RETURN" class="filter-chip <%= activeAction === 'VOTE_RETURN' ? 'active' : '' %>">↩ Votos Devolvidos</a>
        <a href="/admin/logs?action=MOVIE_ADD" class="filter-chip <%= activeAction === 'MOVIE_ADD' ? 'active' : '' %>">➕ Filmes Adicionados</a>
        <a href="/admin/logs?action=MOVIE_REMOVE" class="filter-chip <%= activeAction === 'MOVIE_REMOVE' ? 'active' : '' %>">🗑 Filmes Removidos</a>
        <a href="/admin/logs?action=MOVIE_EDIT" class="filter-chip <%= activeAction === 'MOVIE_EDIT' ? 'active' : '' %>">✏️ Edições</a>
        <a href="/admin/logs?action=RESET_ALL" class="filter-chip <%= activeAction === 'RESET_ALL' ? 'active' : '' %>">⚠️ Reset Geral</a>
        <a href="/admin/logs?action=RESET_MOVIE" class="filter-chip <%= activeAction === 'RESET_MOVIE' ? 'active' : '' %>">🔄 Reset Filme</a>
      </div>
    </div>

    <% if (logs.length === 0) { %>
      <div class="empty-logs">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="40" height="40" style="opacity:.25;margin-bottom:.8rem"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <p>Nenhum log encontrado.</p>
      </div>
    <% } else { %>
      <div style="overflow-x:auto; background:var(--surface); border:1px solid var(--border); border-radius:12px;">
        <table class="log-table">
          <thead>
            <tr>
              <th>Ação</th>
              <th>Usuário</th>
              <th>Filme / Detalhe</th>
              <th>Data</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(log) { %>
            <tr>
              <td>
                <% var labels = {
                  VOTE:         { icon: '🗳', text: 'Voto' },
                  VOTE_RETURN:  { icon: '↩', text: 'Votos Devolvidos' },
                  MOVIE_ADD:    { icon: '➕', text: 'Filme Adicionado' },
                  MOVIE_REMOVE: { icon: '🗑', text: 'Filme Removido' },
                  MOVIE_EDIT:   { icon: '✏️', text: 'Filme Editado' },
                  RESET_ALL:    { icon: '⚠️', text: 'Reset Geral' },
                  RESET_MOVIE:  { icon: '🔄', text: 'Reset Filme' }
                }; var lbl = labels[log.action] || { icon: '•', text: log.action }; %>
                <span class="log-badge <%= log.action %>">
                  <%= lbl.icon %> <%= lbl.text %>
                </span>
              </td>

              <td>
                <% if (log.user) { %>
                  <div class="log-user">
                    <% if (log.user.profileImage) { %>
                      <img class="log-avatar" src="<%= log.user.profileImage %>" alt="">
                    <% } else { %>
                      <div class="log-avatar-placeholder">?</div>
                    <% } %>
                    <div>
                      <div class="log-name"><%= log.user.displayName %></div>
                      <div class="log-sub">@<%= log.user.username %></div>
                    </div>
                  </div>
                <% } else { %>
                  <span style="color:var(--muted);font-size:.78rem;">—</span>
                <% } %>
              </td>

              <td>
                <% if (log.action === 'VOTE' || log.action === 'MOVIE_ADD' || log.action === 'MOVIE_EDIT' || log.action === 'RESET_MOVIE') { %>
                  <div class="log-name"><%= log.movie ? log.movie.title : (log.meta && log.meta.title ? log.meta.title : '—') %></div>
                <% } else if (log.action === 'MOVIE_REMOVE') { %>
                  <div class="log-name" style="opacity:.6;text-decoration:line-through"><%= log.meta && log.meta.title ? log.meta.title : '—' %></div>
                  <div class="log-sub">removido</div>
                <% } else if (log.action === 'VOTE_RETURN') { %>
                  <div class="log-name"><%= log.meta && log.meta.targetDisplayName ? log.meta.targetDisplayName : '—' %></div>
                  <div class="log-sub"><%= log.meta && log.meta.votesReturned ? log.meta.votesReturned + ' voto(s) devolvido(s)' : '' %></div>
                <% } else if (log.action === 'RESET_ALL') { %>
                  <span style="color:var(--muted);font-size:.78rem;">todos os votos</span>
                <% } else { %>
                  <span style="color:var(--muted);font-size:.78rem;">—</span>
                <% } %>
              </td>

              <td class="log-time">
                <%= new Date(log.createdAt).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <div class="pagination">
        <a href="/admin/logs?action=<%= activeAction %>&page=<%= page - 1 %>"
           class="page-btn <%= page <= 1 ? 'disabled' : '' %>">← Anterior</a>
        <% for (var p = Math.max(1, page-2); p <= Math.min(totalPages, page+2); p++) { %>
          <a href="/admin/logs?action=<%= activeAction %>&page=<%= p %>"
             class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
        <% } %>
        <a href="/admin/logs?action=<%= activeAction %>&page=<%= page + 1 %>"
           class="page-btn <%= page >= totalPages ? 'disabled' : '' %>">Próxima →</a>
      </div>
      <% } %>
    <% } %>
  </main>
</div>

<script>
  var activeAction = '<%= activeAction %>';

  // Toast
  function showToast(msg, type) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'show ' + type;
    setTimeout(function() { t.className = ''; }, 2800);
  }

  // Modal
  var modal      = document.getElementById('clearModal');
  var modalTitle = document.getElementById('modalTitle');
  var modalDesc  = document.getElementById('modalDesc');
  var btnClear   = document.getElementById('btnClear');
  var btnCancel  = document.getElementById('modalCancel');
  var btnConfirm = document.getElementById('modalConfirm');

  if (btnClear) {
    btnClear.addEventListener('click', function() {
      if (activeAction) {
        modalTitle.textContent = 'Limpar logs do filtro';
        modalDesc.textContent  = 'Todos os logs do tipo "' + activeAction + '" serão removidos. Esta ação não pode ser desfeita.';
      } else {
        modalTitle.textContent = 'Limpar todos os logs';
        modalDesc.textContent  = 'Todos os registros de auditoria serão removidos permanentemente. Esta ação não pode ser desfeita.';
      }
      modal.classList.add('open');
    });
  }

  btnCancel.addEventListener('click', function() {
    modal.classList.remove('open');
  });

  modal.addEventListener('click', function(e) {
    if (e.target === modal) modal.classList.remove('open');
  });

  btnConfirm.addEventListener('click', function() {
    modal.classList.remove('open');
    btnConfirm.disabled = true;

    var url = '/api/admin/logs' + (activeAction ? '?action=' + activeAction : '');

    fetch(url, { method: 'DELETE' })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.success) {
          showToast('✓ ' + data.deleted + ' log(s) removido(s)', 'ok');
          setTimeout(function() { location.reload(); }, 1200);
        } else {
          showToast('Erro ao limpar logs', 'err');
          btnConfirm.disabled = false;
        }
      })
      .catch(function() {
        showToast('Erro de conexão', 'err');
        btnConfirm.disabled = false;
      });
  });
</script>
